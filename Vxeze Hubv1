-- ESP Trứng (chức năng thật)
local ESP_Enabled = false
local espConnection = nil

local function createEggESP(egg)
    if egg:FindFirstChild("EggESP") then return end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "EggESP"
    billboard.Adornee = egg:FindFirstChildWhichIsA("BasePart") or egg
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 180, 0, 60)
    billboard.StudsOffset = Vector3.new(0, 4, 0)
    billboard.Parent = egg

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = "🪺 " .. egg.Name
    textLabel.TextColor3 = Color3.fromRGB(255, 85, 255)
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    textLabel.Parent = billboard
end

local function removeAllEggESP()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:FindFirstChild("EggESP") then
            obj.EggESP:Destroy()
        end
    end
end

local function startESP()
    if espConnection then return end
    espConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if not ESP_Enabled then
            espConnection:Disconnect()
            espConnection = nil
            return
        end
        for _, v in ipairs(workspace:GetDescendants()) do
            if v.Name:lower():find("egg") and (v:IsA("Model") or v:IsA("Part")) then
                createEggESP(v)
            end
        end
    end)
end

local Toggle = EventEggTab:AddToggle("EggESPToggle", {
    Title = "Bật ESP Trứng", 
    Default = false,
    Description = "Hiển thị trứng qua tường"
})

Toggle:OnChanged(function(Value)
    ESP_Enabled = Value
    if Value then
        Fluent:Notify({Title = "Vxeze Hub", Content = "ESP ON", Duration = 2})
        -- Chạy vòng lặp quét trứng
        task.spawn(function()
            while ESP_Enabled do
                for _, v in ipairs(workspace:GetDescendants()) do
                    if not ESP_Enabled then break end
                    if v.Name:lower():find("egg") and (v:IsA("Model") or v:IsA("Part")) then
                        createEggESP(v)
                    end
                end
                task.wait(2)
            end
        end)
    else
        -- Xóa ESP
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "EggESP" then obj:Destroy() end
        end
        Fluent:Notify({Title = "Vxeze Hub", Content = "ESP OFF", Duration = 2})
    end
end)

