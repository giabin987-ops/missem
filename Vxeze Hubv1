    end
})

--------------------------------------------------
-- VÒNG LẶP LOGIC (Fix lỗi kẹt phím và quái chết)
--------------------------------------------------

-- Vòng lặp Auto Skill
task.spawn(function()
    local VIM = game:GetService("VirtualInputManager")
    while task.wait(0.5) do
        if getgenv().AutoSkill then
            for Key, State in pairs(getgenv().SelectSkills) do
                if State then
                    VIM:SendKeyEvent(true, Key, false, game)
                    task.wait(0.1)
                    VIM:SendKeyEvent(false, Key, false, game)
                end
            end
        end
    end
end)

-- Vòng lặp Farm Loop
task.spawn(function()
    while task.wait() do
        if getgenv().LevelFarm then
            pcall(function()
                local Data = GetFarmData()
                local Character = game.Players.LocalPlayer.Character
                if Data and Character and Character:FindFirstChild("HumanoidRootPart") then
                    -- Tìm quái theo tên trong folder Enemies
                    local enemyFolder = workspace:FindFirstChild("Enemies")
                    local targetMob = enemyFolder and enemyFolder:FindFirstChild(Data.Mob)
                    
                    -- Kiểm tra quái còn sống mới bay vào
                    if targetMob and targetMob:FindFirstChild("HumanoidRootPart") and targetMob.Humanoid.Health > 0 then
                        Character.HumanoidRootPart.CFrame = targetMob.HumanoidRootPart.CFrame * CFrame.new(0, getgenv().DistanceFarmY, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                    end
                end
            end)
        end
    end
end)

