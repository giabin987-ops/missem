-- HÀM FIX TẮT/MỞ UI
local uiVisible = true
LuffyBtn.MouseButton1Click:Connect(function()
    uiVisible = not uiVisible
    
    -- Cách fix: Tìm đúng ScreenGui của WindUI dựa trên Folder name
    local TargetUI = CoreGui:FindFirstChild("tnhuw")
    if TargetUI then
        TargetUI.Enabled = uiVisible
    end
    
    -- Hiệu ứng nhấn mượt
    TweenService:Create(LuffyBtn, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Size = UDim2.fromOffset(52, 52)}):Play()
    task.wait(0.1)
    TweenService:Create(LuffyBtn, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Size = UDim2.fromOffset(60, 60)}):Play()
end)

-- Kéo thả mượt mà (Draggable)
local dragging, dragInput, dragStart, startPos
LuffyBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = LuffyBtn.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
LuffyBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        TweenService:Create(LuffyBtn, TweenInfo.new(0.15), {Position = targetPos}):Play()
    end
end)

