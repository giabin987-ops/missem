local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "W-Azure | Sailor Piece",
    SubTitle = "by Senpai (Optimized)",
    TabWidth = 160,
    Size = UDim2.fromOffset(580,460)
})

-- TABS
local SettingFarm = Window:AddTab({Title="Setting Farm"})
local Farming = Window:AddTab({Title="Farming"})

-- VARIABLES (Lưu trữ lựa chọn)
local SelectedWeapon = "Melee"
local SelectedSkills = {}

-- SETTING FARM TAB
SettingFarm:AddParagraph({
    Title = "Configuration",
    Content = "Thiết lập vũ khí và kỹ năng bổ trợ."
})

-- 1. Select Weapon
local WeaponDropdown = SettingFarm:AddDropdown("WeaponSelect", {
    Title = "Select Weapon",
    Values = {"Melee", "Sword", "Fruit"},
    Multi = false,
    Default = "Melee",
})

WeaponDropdown:OnChanged(function(Value)
    SelectedWeapon = Value
end)

-- 2. Select Skills (Chọn nhiều kỹ năng cùng lúc)
local SkillDropdown = SettingFarm:AddDropdown("SkillSelect", {
    Title = "Select Skills",
    Description = "Chọn các chiêu thức sẽ tung ra",
    Values = {"Z", "X", "C", "V", "B"},
    Multi = true,
    Default = {},
})

SkillDropdown:OnChanged(function(Value)
    SelectedSkills = Value -- Trả về một bảng (table) các chiêu đã chọn
end)

-- 3. Auto Skill Toggle
local AutoSkillToggle = SettingFarm:AddToggle("AutoSkill", {Title = "Auto Skill", Default = false})

-- Logic chạy ngầm cho Auto Skill
task.spawn(function()
    while true do
        task.wait(0.1)
        if AutoSkillToggle.Value then
            for skill, state in pairs(SelectedSkills) do
                if state then
                    -- Gửi tín hiệu nhấn phím ảo (Cần script hỗ trợ nhấn phím hoặc Remote)
                    game:GetService("VirtualInputManager"):SendKeyEvent(true, skill, false, game)
                    task.wait(0.1)
                end
            end
        end
    end
end)

Window:SelectTab(1)
