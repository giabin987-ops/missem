local Fluent = loadstring(game:HttpGet("https://github.com"))()

local Window = Fluent:CreateWindow({
    Title = "W-Azure | Sailor Piece",
    SubTitle = "by Senpai",
    TabWidth = 160,
    Size = UDim2.fromOffset(580,460)
})

-- Tabs
local SettingFarm = Window:AddTab({Title="Setting Farm"})
local Farming = Window:AddTab({Title="Farming"})

-- GLOBAL (Giữ nguyên các biến của bạn)
getgenv().AutoSkill = false
getgenv().LevelFarm = false
getgenv().SelectSkills = {}
getgenv().DistanceFarmY = 10

--------------------------------------------------
-- HIỂN THỊ LEVEL (Sửa để nó tự cập nhật chữ)
--------------------------------------------------
local LevelDisplay = Farming:AddParagraph({
    Title = "Player Level",
    Content = "Loading..."
})

function GetPlayerLevel()
    local player = game.Players.LocalPlayer
    if player:FindFirstChild("Data") and player.Data:FindFirstChild("Level") then
        return player.Data.Level.Value
    end
    return 0
end

task.spawn(function()
    while task.wait(1) do
        local level = GetPlayerLevel()
        LevelDisplay:SetContent("Current Level: " .. tostring(level))
    end
end)

--------------------------------------------------
-- FARM LIST (Giữ nguyên list quái)
--------------------------------------------------
local FarmList = {
    {Min=0,Max=100,Mob="Bandit"},
    {Min=101,Max=300,Mob="Pirate"},
    {Min=301,Max=600,Mob="Brute"},
    {Min=601,Max=1000,Mob="Desert Bandit"},
    {Min=1001,Max=1500,Mob="Marine Soldier"},
    {Min=1501,Max=2000,Mob="Frost Rogue"},
    {Min=2001,Max=3000,Mob="Sorcerer"},
    {Min=3001,Max=4000,Mob="Curse Spirit"},
    {Min=4001,Max=5000,Mob="Slime Warrior"},
    {Min=5001,Max=99999,Mob="Arena Fighter"}
}

function GetFarmData()
    local level = GetPlayerLevel()
    for i,v in pairs(FarmList) do
        if level >= v.Min and level <= v.Max then
            return v
        end
    end
end

