-- ==================== 1. KHỞI TẠO NÚT LUFFY TRƯỚC ====================
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

-- Xóa nút cũ nếu có để tránh lỗi chạy lại script
if CoreGui:FindFirstChild("LuffyToggleGui") then
    CoreGui.LuffyToggleGui:Destroy()
end

local ToggleGui = Instance.new("ScreenGui")
ToggleGui.Name = "LuffyToggleGui"
ToggleGui.Parent = CoreGui
ToggleGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

local LuffyBtn = Instance.new("ImageButton")
LuffyBtn.Name = "LuffyBtn"
LuffyBtn.Parent = ToggleGui
LuffyBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
LuffyBtn.BackgroundTransparency = 0.3
LuffyBtn.Position = UDim2.new(0, 30, 0, 350) -- Góc trái dưới
LuffyBtn.Size = UDim2.new(0, 60, 0, 60)
LuffyBtn.Image = "rbxassetid://14417128661" -- Ảnh Luffy
LuffyBtn.Active = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(1, 0)
UICorner.Parent = LuffyBtn

local UIStroke = Instance.new("UIStroke")
UIStroke.Thickness = 3
UIStroke.Color = Color3.fromRGB(255, 0, 0) -- Viền đỏ Luffy
UIStroke.Parent = LuffyBtn

-- Hiệu ứng kéo thả mượt
local dragging, dragInput, dragStart, startPos
LuffyBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = LuffyBtn.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

LuffyBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        TweenService:Create(LuffyBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Position = targetPos}):Play()
    end
end)

