LuffyBtn.BackgroundTransparency = 0.3
LuffyBtn.Position = UDim2.new(0, 30, 0, 250) -- Dịch lên trên (số 250 nhỏ hơn 350)
LuffyBtn.Size = UDim2.new(0, 60, 0, 60)
LuffyBtn.Image = "rbxassetid://14417128661" 
