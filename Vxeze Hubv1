local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "Vxeze Hub",
    SubTitle = "by Senpai",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.RightControl
})

-- ==================== TAB EVENT EGG ====================
local EventEggTab = Window:AddTab({ Title = "Event Egg", Icon = "egg" })
local ESP_Enabled = false

-- Hàm tạo ESP (Đã thêm kiểm tra lỗi)
local function createEggESP(obj)
    if obj:FindFirstChild("EggESP") then return end
    
    local targetPart = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
    if not targetPart then return end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "EggESP"
    billboard.Adornee = targetPart
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 100, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.Parent = obj

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = "🥚 " .. obj.Name
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextStrokeTransparency = 0
    textLabel.Parent = billboard
end

-- ==================== TOGGLE VỚI NOTIFY ====================
local EggToggle = EventEggTab:AddToggle("EggESPToggle", {
    Title = "ESP Trứng Event", 
    Default = false,
    Description = "Hiển thị vị trí trứng qua tường"
})

EggToggle:OnChanged(function(Value)
    ESP_Enabled = Value
    
    if Value then
        -- Thông báo khi BẬT
        Fluent:Notify({
            Title = "Vxeze Hub",
            Content = "Đã BẬT ESP Trứng! Đang quét bản đồ...",
            SubTitle = "Hệ thống ESP",
            Duration = 3
        })
        
        -- Chạy vòng lặp quét trứng liên tục khi đang bật
        task.spawn(function()
            while ESP_Enabled do
                pcall(function()
                    for _, v in ipairs(workspace:GetDescendants()) do
                        if not ESP_Enabled then break end
                        -- Kiểm tra tên (egg, event, hoặc tên quả trứng cụ thể của game)
                        if (v.Name:lower():find("egg") or v.Name:lower():find("event")) and (v:IsA("Model") or v:IsA("BasePart")) then
                            createEggESP(v)
                        end
                    end
                end)
                task.wait(2) -- Quét lại sau mỗi 2 giây để cập nhật trứng mới spawn
            end
        end)
    else
        -- Thông báo khi TẮT
        Fluent:Notify({
            Title = "Vxeze Hub",
            Content = "Đã TẮT ESP Trứng.",
            SubTitle = "Hệ thống ESP",
            Duration = 3
        })
        
        -- Xóa tất cả ESP đang hiện
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "EggESP" then
                obj:Destroy()
            end
        end
    end
end)

