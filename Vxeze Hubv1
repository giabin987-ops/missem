-- [[ NOCLIP ỔN ĐỊNH ]]
local noClipEnabled = false
local RunService = game:GetService("RunService")
local noClipConn = nil

function StartNoClip()
    if noClipConn then return end
    noClipEnabled = true
    noClipConn = RunService.Stepped:Connect(function()
        if not noClipEnabled then return end
        local char = player.Character
        if not char then return end
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") and v.CanCollide then
                v.CanCollide = false
            end
        end
    end)
end

function StopNoClip()
    noClipEnabled = false
    if noClipConn then
        noClipConn:Disconnect()
        noClipConn = nil
    end
end

-- [[ FIX DẬT VỀ CHỖ CŨ: Lerp từng bước nhỏ ]]
function TweenTo(cf)
    local char = player.Character
    if not char then return nil end

    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not root then return nil end

    if _G.CurrentTween then
        _G.CurrentTween:Cancel()
        _G.CurrentTween = nil
    end

    -- Tắt humanoid để server không override vị trí
    if humanoid then
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
    end

    root.Anchored = true

    local dist = (cf.Position - root.Position).Magnitude

    -- Gần thì TP thẳng
    if dist < 300 then
        root.CFrame = cf
        root.Anchored = false
        if humanoid then
            humanoid.WalkSpeed = 16
            humanoid.JumpPower = 50
        end
        return nil
    end

    -- Xa thì lerp từng bước ~250 studs, delay 0.07s để server chấp nhận
    local startCF = root.CFrame
    local steps = math.ceil(dist / 250)
    local done = false

    task.spawn(function()
        for i = 1, steps do
            if not _G.AutoCyborg then break end
            local alpha = i / steps
            root.CFrame = startCF:Lerp(cf, alpha)
            task.wait(0.07)
        end

        root.CFrame = cf
        root.Anchored = false
        done = true

        if humanoid then
            humanoid.WalkSpeed = 16
            humanoid.JumpPower = 50
        end
    end)

    -- Chờ lerp xong
    repeat task.wait(0.05) until done or not _G.AutoCyborg

    return nil
end

-- [[ FIND CHEST ]]
function GetRealChest()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local target, distMin = nil, math.huge

    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart")
        and string.find(v.Name, "Chest")
        and v:FindFirstChild("TouchInterest")
        and not VisitedChests[v] then
            local dist = (v.Position - root.Position).Magnitude
            if dist < distMin then
                distMin = dist
                target = v
            end
        end
    end

    return target
end

-- [[ HOP SERVER ]]
function HopServer()
    VisitedChests = {}
    local TPS = game:GetService("TeleportService")

    local success = false
    pcall(function()
        local Api = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
        local r = game:GetService("HttpService"):JSONDecode(game:HttpGet(Api))
        if r and r.data then
            for _, v in pairs(r.data) do
                if v.playing < v.maxPlayers and v.id ~= game.JobId then
                    TPS:TeleportToPlaceInstance(game.PlaceId, v.id, player)
                    success = true
                    return
                end
            end
        end
    end)

    if not success then
        task.wait(1)
        pcall(function()
            TPS:Teleport(game.PlaceId, player)
        end)
    end
end

-- [[ MAIN ]]
function MainLogic()
    repeat task.wait() until player.Character and player.Character:FindFirstChild("HumanoidRootPart")

    StartNoClip()

    local retry = 0

    while _G.AutoCyborg do
        task.wait(0.1)

        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")

        if root then
            local Fist = char:FindFirstChild("Fist of Darkness")
                or player.Backpack:FindFirstChild("Fist of Darkness")

            if Fist then
                if _G.CurrentTween then
                    _G.CurrentTween:Cancel()
                    _G.CurrentTween = nil
                end

                TweenTo(CFrame.new(-6473, 250, -4493))

                pcall(function()
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("BuyMicrochip")
                end)

                task.wait(0.3)

                TweenTo(CFrame.new(-6475, 250, -4490))

                pcall(function()
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartRaid")
                end)

                _G.AutoCyborg = false
                break
            end

            local chest = GetRealChest()

            if chest then
                retry = 0

                TweenTo(chest.CFrame + Vector3.new(0, 3, 0))

                if chest and chest.Parent and firetouchinterest then
                    for i = 1, 3 do
                        pcall(function()
                            firetouchinterest(root, chest, 0)
                            firetouchinterest(root, chest, 1)
                        end)
                        task.wait(0.1)
                    end
                end

                VisitedChests[chest] = true
            else
                retry += 1
                task.wait(5)

                if retry >= 5 then
                    StopNoClip()
                    HopServer()
                    break
                end
            end
        end
    end

    StopNoClip()
    isRunning = false
    mouseLoop = false
end

