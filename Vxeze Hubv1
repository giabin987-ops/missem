-- [[ NOCLIP ]]
local noClipConn = nil

function StartNoClip()
    if noClipConn then return end
    noClipConn = RunService.Stepped:Connect(function()
        local char = player.Character
        if not char then return end
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
            end
        end
    end)
end

function StopNoClip()
    if noClipConn then
        noClipConn:Disconnect()
        noClipConn = nil
    end
end

-- [[ GIỮ Y KHÔNG XUỐNG NƯỚC ]]
local MIN_Y = 30

function SafeCF(cf)
    local pos = cf.Position
    if pos.Y < MIN_Y then
        pos = Vector3.new(pos.X, MIN_Y, pos.Z)
    end
    return CFrame.new(pos) * (cf - cf.Position)
end

-- [[ XÓA VELOCITY ]]
function ClearVelocity()
    pcall(function()
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        for _, v in pairs(root:GetChildren()) do
            if v:IsA("LinearVelocity") or v:IsA("Attachment") then
                v:Destroy()
            end
        end
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end)
end

-- [[ BAY ]]
function TweenTo(targetCF)
    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not root then return end

    targetCF = SafeCF(targetCF)
    ClearVelocity()

    if _G.CurrentTween then
        pcall(function() _G.CurrentTween:Cancel() end)
        _G.CurrentTween = nil
    end

    local dist = (targetCF.Position - root.Position).Magnitude
    if dist < 5 then return end

    pcall(function()
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
        humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    end)

    local speed = _G.TweenSpeed
    local direction = (targetCF.Position - root.Position).Unit

    local att = Instance.new("Attachment")
    att.Parent = root

    local lv = Instance.new("LinearVelocity")
    lv.Attachment0 = att
    lv.VectorVelocity = direction * speed
    lv.MaxForce = math.huge
    lv.RelativeTo = Enum.ActuatorRelativeTo.World
    lv.Parent = root

    local lookConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            if root.Position.Y < MIN_Y then
                root.CFrame = CFrame.new(root.Position.X, MIN_Y, root.Position.Z)
            end
            local lookDir = targetCF.Position - root.Position
            if lookDir.Magnitude > 5 then
                root.CFrame = CFrame.lookAt(
                    root.Position,
                    root.Position + Vector3.new(lookDir.X, 0, lookDir.Z)
                )
            end
        end)
    end)

    local timeout = (dist / speed) + 3
    local elapsed = 0
    local arrived = false

    repeat
        task.wait(0.05)
        elapsed += 0.05
        if (targetCF.Position - root.Position).Magnitude < 10 then
            arrived = true
        end
    until arrived or elapsed >= timeout or not _G.AutoCyborg

    lookConn:Disconnect()
    lv:Destroy()
    att:Destroy()

    -- Dừng hoàn toàn
    ClearVelocity()
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    if arrived and (targetCF.Position - root.Position).Magnitude < 30 then
        root.CFrame = targetCF
    end

    task.wait(0.1)

    pcall(function()
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end)
end

-- [[ LƯỢM RƯƠNG ]]
function TouchChest(chest)
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not root then return end

    TweenTo(CFrame.new(chest.Position.X, chest.Position.Y + 2, chest.Position.Z))

    -- Dừng hoàn toàn trước khi lượm
    ClearVelocity()
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    root.Anchored = true

    pcall(function()
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
        humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
    end)

    -- Snap cứng vào rương không cho trượt qua
    root.CFrame = CFrame.new(chest.Position.X, chest.Position.Y + 2, chest.Position.Z)
    task.wait(0.2)

    -- Lượm
    for i = 1, 8 do
        if not chest or not chest.Parent then break end
        pcall(function()
            root.CFrame = CFrame.new(chest.Position.X, chest.Position.Y + 2, chest.Position.Z)
            if firetouchinterest then
                firetouchinterest(root, chest, 0)
                task.wait(0.05)
                firetouchinterest(root, chest, 1)
                task.wait(0.05)
                firetouchinterest(root, chest, 0)
            end
        end)
        task.wait(0.1)
    end

    task.wait(0.2)

    -- Reset sau lượm
    ClearVelocity()
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    root.Anchored = false

    task.wait(0.1)

    pcall(function()
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end)
end

-- [[ FIND CHEST ]]
function GetRealChest()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local target, distMin = nil, math.huge

    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart")
        and string.find(v.Name, "Chest")
        and v:FindFirstChild("TouchInterest")
        and not VisitedChests[v] then
            local dist = (v.Position - root.Position).Magnitude
            if dist < distMin then
                distMin = dist
                target = v
            end
        end
    end

    return target
end

-- [[ HOP SERVER ]]
function HopServer()
    VisitedChests = {}
    chestCount = 0

    ShowNotify("Vxeze Hub Hop Server", Color3.fromRGB(0, 191, 255), 4)
    task.wait(1.5)

    local TPS = game:GetService("TeleportService")
    local success = false

    for attempt = 1, 3 do
        if success then break end
        pcall(function()
            local Http = game:GetService("HttpService")
            local Api = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
            local r = Http:JSONDecode(game:HttpGet(Api))
            if r and r.data then
                for _, v in pairs(r.data) do
                    if v.id ~= game.JobId
                    and v.playing ~= nil
                    and v.maxPlayers ~= nil
                    and v.playing < v.maxPlayers then
                        TPS:TeleportToPlaceInstance(game.PlaceId, v.id, player)
                        success = true
                        return
                    end
                end
            end
        end)
        if not success then task.wait(2) end
    end

    if not success then
        ShowNotify("API bị chặn, dùng Teleport thường...", Color3.fromRGB(255, 165, 0), 3)
        task.wait(1)
        pcall(function()
            TPS:Teleport(game.PlaceId, player)
        end)
    end
end

-- [[ MAIN ]]
function MainLogic()
    repeat task.wait() until player.Character and player.Character:FindFirstChild("HumanoidRootPart")

    StartNoClip()
    chestCount = 0

    local retry = 0

    while _G.AutoCyborg do
        task.wait(0.1)

        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")

        if root then
            local Fist = char:FindFirstChild("Fist of Darkness")
                or player.Backpack:FindFirstChild("Fist of Darkness")

            if Fist then
                TweenTo(CFrame.new(-6473, 250, -4493))
                pcall(function()
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("BuyMicrochip")
                end)
                task.wait(0.3)
                TweenTo(CFrame.new(-6475, 250, -4490))
                pcall(function()
                    game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartRaid")
                end)
                _G.AutoCyborg = false
                break
            end

            local chest = GetRealChest()

            if chest then
                retry = 0

                TouchChest(chest)

                VisitedChests[chest] = true
                chestCount += 1

                -- Hop server sau 20 rương
                if chestCount >= 20 then
                    ShowNotify("Vxeze Hub Hop Server", Color3.fromRGB(0, 191, 255), 4)
                    task.wait(1.5)
                    StopNoClip()
                    HopServer()
                    break
                end
            else
                retry += 1
                task.wait(5)

                if retry >= 5 then
                    StopNoClip()
                    HopServer()
                    break
                end
            end
        end
    end

    StopNoClip()
    isRunning = false
    mouseLoop = false
end

