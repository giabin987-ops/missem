local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local Vim = game:GetService("VirtualInputManager")

local Window = Fluent:CreateWindow({
    Title = "W-Azure | Sailor Piece",
    SubTitle = "by Senpai (Optimized)",
    TabWidth = 160,
    Size = UDim2.fromOffset(580,460)
})

local SettingFarm = Window:AddTab({Title="Setting Farm"})
local Farming = Window:AddTab({Title="Farming"})

-- Biến lưu trữ
local SelectedWeapon = "Melee"
local SelectedSkills = {}

-- 1. Select Weapon
local WeaponDropdown = SettingFarm:AddDropdown("WeaponSelect", {
    Title = "Select Weapon",
    Values = {"Melee", "Sword", "Fruit"},
    Multi = false,
    Default = "Melee",
})
WeaponDropdown:OnChanged(function(Value) SelectedWeapon = Value end)

-- 2. FIX SELECT SKILLS (Thêm phím F và sửa logic lưu trữ)
local SkillDropdown = SettingFarm:AddDropdown("SkillSelect", {
    Title = "Select Skills",
    Values = {"Z", "X", "C", "V", "F"},
    Multi = true,
    Default = {},
})

SkillDropdown:OnChanged(function(Value)
    SelectedSkills = {}
    for i, v in pairs(Value) do
        SelectedSkills[i] = v
    end
end)

-- 3. FIX AUTO SKILL (Sử dụng vòng lặp kiểm tra bảng hiệu quả hơn)
local AutoSkillToggle = SettingFarm:AddToggle("AutoSkill", {Title = "Auto Skill", Default = false})

task.spawn(function()
    while task.wait(0.5) do -- Nghỉ 0.5s để tránh spam quá nhanh gây lag
        if AutoSkillToggle.Value then
            for skillName, enabled in pairs(SelectedSkills) do
                if enabled then
                    -- Nhấn phím
                    Vim:SendKeyEvent(true, skillName, false, game)
                    task.wait(0.1)
                    Vim:SendKeyEvent(false, skillName, false, game)
                end
            end
        end
    end
end)

Window:SelectTab(1)
