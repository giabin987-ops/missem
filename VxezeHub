-- ==================== AUTO WIN ĐỘNG VẬT (Giữ nguyên bay trời) ====================
local animalConnection = nil
local animalTargetY = nil

local function StartAnimalWin()
    if animalConnection then return end
    animalTargetY = nil

    animalConnection = game:GetService("RunService").Stepped:Connect(function()
        local char = game.Players.LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp or not (AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal") then 
            animalTargetY = nil return 
        end

        if not animalTargetY then animalTargetY = hrp.Position.Y + 420 end

        if hrp.Position.Y < animalTargetY then
            hrp.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y + 1.8, hrp.Position.Z)
        else
            hrp.CFrame = CFrame.new(hrp.Position.X, animalTargetY, hrp.Position.Z)
        end

        hrp.Velocity = Vector3.new(0,0,0)
        hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
    end)
end

local function StopAnimalWin()
    if animalConnection then animalConnection:Disconnect() end
    animalConnection = nil
end

-- ==================== AUTO WIN NGƯỜI BẮN (Tele dính + Aim + Bắn liên tục) ====================
local seekerConnection = nil
local currentTarget = nil

local function GetClosestAnimal()
    local myChar = game.Players.LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myChar.HumanoidRootPart.Position
    local closest, dist = nil, math.huge

    for _, p in ipairs(game.Players:GetPlayers()) do
        if p == game.Players.LocalPlayer then continue end
        if GetType(p) ~= "Animal" then continue end
        local char = p.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") or char.Humanoid.Health <= 0 then continue end

        local d = (char.HumanoidRootPart.Position - myPos).Magnitude
        if d < dist then
            dist = d
            closest = char
        end
    end
    return closest
end

local function StartSeekerWin()
    if seekerConnection then return end

    seekerConnection = game:GetService("RunService").Stepped:Connect(function()
        local char = game.Players.LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp or not (AutoWin_Seeker and GetType(game.Players.LocalPlayer) == "Boss") then 
            currentTarget = nil return 
        end

        -- Tìm target mới nếu target cũ chết hoặc không có
        if not currentTarget or not currentTarget.Parent or currentTarget.Humanoid.Health <= 0 then
            currentTarget = GetClosestAnimal()
        end

        if currentTarget and currentTarget:FindFirstChild("HumanoidRootPart") then
            local targetHRP = currentTarget.HumanoidRootPart
            local targetHead = currentTarget:FindFirstChild("Head")

            -- TELE DÍNH VÀO TRONG NGƯỜI CHƠI
            hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0, -1.5)   -- dính sát vào thân

            -- AIM (nhắm đầu)
            if targetHead then
                workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, targetHead.Position)
            end

            -- BẮN LIÊN TỤC
            local tool = char:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Handle") then
                tool:Activate()   -- bắn liên tục
            end
        end
    end)
end

local function StopSeekerWin()
    if seekerConnection then seekerConnection:Disconnect() end
    seekerConnection = nil
    currentTarget = nil
end

-- Theo dõi toggle
game:GetService("RunService").Heartbeat:Connect(function()
    -- Động vật
    if AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal" then
        if not animalConnection then StartAnimalWin() end
    else
        if animalConnection then StopAnimalWin() end
    end

    -- Người bắn
    if AutoWin_Seeker and GetType(game.Players.LocalPlayer) == "Boss" then
        if not seekerConnection then StartSeekerWin() end
    else
        if seekerConnection then StopSeekerWin() end
    end
end)

-- ==================== SPEED + NOCLIP + INF JUMP ====================
game:GetService("RunService").Stepped:Connect(function()
    local char = game.Players.LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    hum.WalkSpeed = WalkSpeed_Val

    local isFlying = (AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal") or
                     (AutoWin_Seeker and GetType(game.Players.LocalPlayer) == "Boss")

    if Noclip or isFlying then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

-- Nhảy vô hạn
game:GetService("UserInputService").JumpRequest:Connect(function()
    if InfJump then
        local hum = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState("Jumping") end
    end
end)

-- ==================== ESP GIỮ NGUYÊN ====================
local function CreateESP(p)
    local tracer = Drawing.new("Line")
    local label = Drawing.new("Text")
    game:GetService("RunService").RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local hrp = p.Character.HumanoidRootPart
            local vec, onScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            local pType = GetType(p)
            local active = (pType == "Animal" and ESP_Animals) or (pType == "Boss" and ESP_Boss)
            local color = (pType == "Animal") and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)

            if onScreen and active then
                local dist = math.floor((game.Players.LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude)
                tracer.Visible, tracer.From, tracer.To, tracer.Color = true, 
                    Vector2.new(game.Workspace.CurrentCamera.ViewportSize.X/2, game.Workspace.CurrentCamera.ViewportSize.Y), 
                    Vector2.new(vec.X, vec.Y), color
                label.Visible, label.Position, label.Text, label.Color = true, 
                    Vector2.new(vec.X, vec.Y - 40), 
                    string.format("%s [%dm]", p.Name, dist), color
                label.Size, label.Center, label.Outline = 14, true, true
            else
                tracer.Visible, label.Visible = false, false
            end
        else
            tracer.Visible, label.Visible = false, false
        end
    end)
end

for _, p in ipairs(game.Players:GetPlayers()) do 
    if p ~= game.Players.LocalPlayer then CreateESP(p) end 
end
game.Players.PlayerAdded:Connect(CreateESP)

