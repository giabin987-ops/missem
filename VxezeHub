local function GetType(p)
    if not p.Team then return nil end
    local n = p.Team.Name:lower()
    if n:find("animal") or n:find("hider") or n:find("thú") then return "Animal" end
    if n:find("keeper") or n:find("seeker") or n:find("boss") or n:find("staff") then return "Boss" end
    return nil
end

