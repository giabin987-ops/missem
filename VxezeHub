-- Auto Win Logic (Fix dật + chỉ xuống vừa đủ)
local autoWinConnection = nil

local function StartAutoWin()
    if autoWinConnection then return end
    
    autoWinConnection = game:GetService("RunService").Stepped:Connect(function()
        local char = game.Players.LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end

        if AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal" then
            -- Bay xuống vừa đủ (chỉ ẩn phần đầu)
            hrp.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y - 0.5, hrp.Position.Z) -- di chuyển từ từ xuống
            hum.PlatformStand = true
            
            -- Giữ velocity = 0 để không rơi thêm
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        else
            hum.PlatformStand = false
        end
    end)
end

local function StopAutoWin()
    if autoWinConnection then
        autoWinConnection:Disconnect()
        autoWinConnection = nil
    end
    local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.PlatformStand = false end
end

-- Theo dõi toggle AutoWin
game:GetService("RunService").Heartbeat:Connect(function()
    if AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal" then
        if not autoWinConnection then
            StartAutoWin()
        end
    else
        if autoWinConnection then
            StopAutoWin()
        end
    end
end)

-- Noclip + Speed + InfJump (giữ nguyên logic cũ)
game:GetService("RunService").Stepped:Connect(function()
    local char = game.Players.LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    hum.WalkSpeed = WalkSpeed_Val

    if Noclip or (AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal") then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- Nhảy vô hạn
game:GetService("UserInputService").JumpRequest:Connect(function()
    if InfJump then
        local hum = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState("Jumping") end
    end
end)

-- ==================== ESP GIỮ NGUYÊN ====================
local function CreateESP(p)
    local tracer = Drawing.new("Line")
    local label = Drawing.new("Text")

    game:GetService("RunService").RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local hrp = p.Character.HumanoidRootPart
            local vec, onScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            local pType = GetType(p)
            local active = (pType == "Animal" and ESP_Animals) or (pType == "Boss" and ESP_Boss)
            local color = (pType == "Animal") and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)

            if onScreen and active then
                local dist = math.floor((game.Players.LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude)
                tracer.Visible, tracer.From, tracer.To, tracer.Color = true, Vector2.new(game.Workspace.CurrentCamera.ViewportSize.X/2, game.Workspace.CurrentCamera.ViewportSize.Y), Vector2.new(vec.X, vec.Y), color
                label.Visible, label.Position, label.Text, label.Color = true, Vector2.new(vec.X, vec.Y - 40), string.format("%s [%dm]", p.Name, dist), color
                label.Size, label.Center, label.Outline = 14, true, true
            else
                tracer.Visible, label.Visible = false, false
            end
        else
            tracer.Visible, label.Visible = false, false
        end
    end)
end

for _, p in ipairs(game.Players:GetPlayers()) do 
    if p ~= game.Players.LocalPlayer then CreateESP(p) end 
end
game.Players.PlayerAdded:Connect(CreateESP)

