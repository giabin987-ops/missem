        if hum then hum:ChangeState("Jumping") end
    end
end)

-- ==================== ESP GIỮ NGUYÊN ====================
local function CreateESP(p)
    local tracer = Drawing.new("Line")
    local label = Drawing.new("Text")

    game:GetService("RunService").RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
            local hrp = p.Character.HumanoidRootPart
            local vec, onScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            local pType = GetType(p)
            local active = (pType == "Animal" and ESP_Animals) or (pType == "Boss" and ESP_Boss)
            local color = (pType == "Animal") and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)

            if onScreen and active then
                local dist = math.floor((game.Players.LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude)
                tracer.Visible, tracer.From, tracer.To, tracer.Color = true, 
                    Vector2.new(game.Workspace.CurrentCamera.ViewportSize.X/2, game.Workspace.CurrentCamera.ViewportSize.Y), 
                    Vector2.new(vec.X, vec.Y), color
                
                label.Visible, label.Position, label.Text, label.Color = true, 
                    Vector2.new(vec.X, vec.Y - 40), 
                    string.format("%s [%dm]", p.Name, dist), color
                label.Size, label.Center, label.Outline = 14, true, true
            else
                tracer.Visible, label.Visible = false, false
            end
        else
            tracer.Visible, label.Visible = false, false
        end
    end)
end

for _, p in ipairs(game.Players:GetPlayers()) do 
    if p ~= game.Players.LocalPlayer then CreateESP(p) end 
end
game.Players.PlayerAdded:Connect(CreateESP)

