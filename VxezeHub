-- ==================== AUTO WIN ĐÃ CẢI TIẾN (CHỈ ẨN ĐẦU) ====================
local autoWinConnection = nil
local currentDepth = -7

-- Bảng độ sâu phù hợp cho từng loại động vật (chỉ đủ không lộ đầu)
local AnimalDepths = {
    ["mouse"] = -4, ["rat"] = -4, ["chicken"] = -5, ["rabbit"] = -5,
    ["snake"] = -6, ["lizard"] = -5, ["cat"] = -6, ["dog"] = -7,
    ["fox"] = -7, ["pig"] = -7, ["deer"] = -8, ["wolf"] = -8,
    ["bear"] = -9, ["lion"] = -9, ["tiger"] = -9, ["gorilla"] = -10,
    ["elephant"] = -12, ["giraffe"] = -11,
    default = -7
}

local function GetAnimalDepth()
    local char = game.Players.LocalPlayer.Character
    if not char then return AnimalDepths.default end
    
    local name = (char.Name .. " " .. game.Players.LocalPlayer.DisplayName):lower()
    
    for animal, depth in pairs(AnimalDepths) do
        if name:find(animal) then
            return depth
        end
    end
    return AnimalDepths.default
end

local function StartAutoWin()
    if autoWinConnection then return end
    
    currentDepth = GetAnimalDepth()
    
    autoWinConnection = game:GetService("RunService").Stepped:Connect(function()
        local char = game.Players.LocalPlayer.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end

        if AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal" then
            hum.PlatformStand = true
            
            -- Di chuyển xuống rất nhẹ nhàng để tránh văng
            local targetY = hrp.Position.Y - 0.6
            local finalY = math.max(targetY, hrp.Position.Y + currentDepth)
            
            hrp.CFrame = CFrame.new(hrp.Position.X, finalY, hrp.Position.Z)
            
            -- Giữ im và chống văng lên
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.AssemblyLinearVelocity = Vector3.new(0, -2.5, 0)
            hrp.AssemblyRootPart = hrp
        else
            hum.PlatformStand = false
        end
    end)
end

local function StopAutoWin()
    if autoWinConnection then
        autoWinConnection:Disconnect()
        autoWinConnection = nil
    end
    local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.PlatformStand = false end
end

-- Theo dõi Auto Win
game:GetService("RunService").Heartbeat:Connect(function()
    if AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal" then
        if not autoWinConnection then StartAutoWin() end
    else
        if autoWinConnection then StopAutoWin() end
    end
end)

-- ==================== SPEED + NOCLIP + INF JUMP ====================
game:GetService("RunService").Stepped:Connect(function()
    local char = game.Players.LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    hum.WalkSpeed = WalkSpeed_Val

    -- Noclip khi bật hoặc đang Auto Win
    if Noclip or (AutoWin_Animal and GetType(game.Players.LocalPlayer) == "Animal") then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- Nhảy vô hạn
