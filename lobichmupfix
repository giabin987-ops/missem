-- [[ HÀM GỬI LỆNH THÔNG MINH - CHỐNG KICK NSE1 (REMOTE FUNCTION) ]]
local function SafeRemote(remote, ...)
    if not remote then return end
    if remote:IsA("RemoteEvent") then 
        remote:FireServer(...)
    elseif remote:IsA("RemoteFunction") then 
        remote:InvokeServer(...) 
    end
end

-- [[ HÀM BAY FIX: NHẢY MỖI 4 GIÂY + DỪNG LẬP TỨC ]]
local function SafeFly(targetCFrame)
    local lp = game.Players.LocalPlayer
    local lastJump = tick()
    while _G.AutoFarm or _G.TweenBoat do
        task.wait()
        local char = lp.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        -- DỪNG NGAY LẬP TỨC KHI TẮT NÚT
        if not root or not (_G.AutoFarm or _G.TweenBoat) then break end
        if (root.Position - targetCFrame.p).Magnitude < 15 then break end 
        
        -- FIX BAY: TỰ ĐỘNG NHẢY MỖI 4 GIÂY ĐỂ NÉ ANTICHEAT
        if tick() - lastJump >= 4 then 
            char.Humanoid.Jump = true 
            lastJump = tick() 
        end
        
        -- BAY CHẬM AN TOÀN (TỐC ĐỘ 80)
        root.CFrame = root.CFrame + (targetCFrame.p - root.Position).Unit * 1.9
        root.Velocity = Vector3.new(0,0,0)
    end
end

-- [[ HÀM TỰ CẦM NẮM ĐẤM (COMBAT) ]]
local function EquipCombat()
    local lp = game.Players.LocalPlayer
    local combat = lp.Backpack:FindFirstChild("Combat") or lp.Character:FindFirstChild("Combat")
    if combat and not lp.Character:FindFirstChild("Combat") then 
        lp.Character.Humanoid:EquipTool(combat) 
    end
end

