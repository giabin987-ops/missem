-- [[ HÀM QUÉT REMOTE THÔNG MINH ]]
local function GetGPRemote(name)
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("RemoteEvent") and (v.Name:find(name) or v.Name == "Stats" or v.Name == "Quest" or v.Name == "Shop") then
            return v
        end
    end
end

-- [[ HÀM BAY CHẬM AN TOÀN (NHẢY + 3S + SLOW TWEEN) ]]
local function SafeFly(targetCFrame)
    local char = game.Players.LocalPlayer.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        char.Humanoid.Jump = true
        task.wait(3) -- Nhảy sau 3 giây rồi mới bay theo yêu cầu
        
        local dist = (root.Position - targetCFrame.p).Magnitude
        local speed = 80 -- Tốc độ chậm an toàn né Fatal Error
        
        char.Humanoid:ChangeState(Enum.HumanoidStateType.Physics)
        local tween = game:GetService("TweenService"):Create(root, TweenInfo.new(dist/speed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
        tween:Play()
        tween.Completed:Wait()
        char.Humanoid:ChangeState(Enum.HumanoidStateType.Standing)
        task.wait(1)
    end
end

