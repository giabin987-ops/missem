-- [[ TAB 2: FARM LVL - KAITUN THÔNG MINH ]]

-- A. CHỨC NĂNG KAITUN CHÍNH
Tabs.Level:AddToggle("AutoFarm", {Title = "Auto Farm Level (Kaitun)", Default = false }):OnChanged(function(v)
    _G.AutoFarm = v
    spawn(function()
        while _G.AutoFarm do
            pcall(function()
                local lp = game.Players.LocalPlayer
                -- Tự quét Level
                local lv = 1
                for _, val in pairs(lp:GetDescendants()) do
                    if val.Name == "Level" and (val:IsA("IntValue") or val:IsA("NumberValue")) then lv = val.Value break end
                end
                
                -- Tìm đảo
                local target = nil
                for _, data in pairs(FarmData) do
                    if lv >= data.Min and lv <= data.Max then target = data break end
                end

                if target then
                    if not lp.PlayerGui:FindFirstChild("QuestGui") then
                        SafeFly(target.NPC)
                        local qRemote = GetGPRemote("Quest")
                        if qRemote then qRemote:FireServer(target.Quest) end
                    else
                        for _, mob in pairs(game.Workspace.NPCs:GetChildren()) do
                            if mob.Name == target.Mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                                SafeFly(mob.HumanoidRootPart.CFrame * CFrame.new(0, 7, 0))
                                game:GetService("VirtualUser"):ClickButton1(Vector2.new(0,0))
                                break
                            end
                        end
                    end
                end
            end)
            task.wait(1)
        end
    end)
end)

