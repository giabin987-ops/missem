-- [[ HÀM BAY FIX: NHẢY MỖI 4S + DỪNG LẬP TỨC ]]
local function SafeFly(targetCFrame)
    local lp = game.Players.LocalPlayer
    local lastJump = tick()
    
    while _G.AutoFarm or _G.TweenBoat do
        task.wait()
        local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not root or not (_G.AutoFarm or _G.TweenBoat) then break end
        
        local dist = (root.Position - targetCFrame.p).Magnitude
        if dist < 10 then break end 

        -- Fix lỗi bay: Nhảy mỗi 4 giây
        if tick() - lastJump >= 4 then
            lp.Character.Humanoid.Jump = true
            lastJump = tick()
        end
        
        -- Bay chậm mượt
        root.CFrame = root.CFrame + (targetCFrame.p - root.Position).Unit * 1.8
        root.Velocity = Vector3.new(0,0,0)
    end
end

-- [[ HÀM TỰ CẦM NẮM ĐẤM ]]
local function EquipCombat()
    local lp = game.Players.LocalPlayer
    local combat = lp.Backpack:FindFirstChild("Combat") or lp.Character:FindFirstChild("Combat")
    if combat then lp.Character.Humanoid:EquipTool(combat) end
end

