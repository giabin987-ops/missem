-- [[ FIX TWEEN MUA THUYỀN ]]
Tabs.Boat:AddToggle("TweenBoat", {Title = "Auto Buy Boat (RowBoat)", Default = false }):OnChanged(function(v)
    _G.TweenBoat = v
    if v then
        task.spawn(function()
            SafeFly(CFrame.new(-33.5, 25, -425.2))
            if _G.TweenBoat then
                local rem = game:GetService("ReplicatedStorage"):FindFirstChild("Events"):FindFirstChild("Shop")
                if rem then rem:FireServer("RowBoat") end
                _G.TweenBoat = false -- Mua xong tự dừng
            end
        end)
    end
end)

-- [[ FIX AUTO FARM & LEVEL CHECK ]]
local LevelLabel = Tabs.Level:AddParagraph({Title = "Level Check", Content = "Checking..."})

Tabs.Level:AddToggle("AutoFarm", {Title = "Auto Farm Level", Default = false }):OnChanged(function(v)
    _G.AutoFarm = v
    if v then
        task.spawn(function()
            while _G.AutoFarm do
                pcall(function()
                    local lp = game.Players.LocalPlayer
                    local lv = lp.Data.Level.Value
                    LevelLabel:SetDesc("Level hiện tại: " .. tostring(lv))
                    
                    local target = nil
                    for _, d in pairs(FarmData) do if lv >= d.Min and lv <= d.Max then target = d break end end

                    if target then
                        EquipCombat() -- Tự cầm đấm
                        if not lp.PlayerGui:FindFirstChild("QuestGui") then
                            SafeFly(target.NPC)
                            local qRem = game:GetService("ReplicatedStorage"):FindFirstChild("Events"):FindFirstChild("Quest")
                            if qRem then qRem:FireServer(target.Quest) end
                        else
                            -- Tìm quái và đánh
                            for _, mob in pairs(game.Workspace.NPCs:GetChildren()) do
                                if mob.Name:find(target.Mob) and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                                    while _G.AutoFarm and mob.Humanoid.Health > 0 do
                                        lp.Character.HumanoidRootPart.CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0, 8, 0)
                                        game:GetService("VirtualUser"):ClickButton1(Vector2.new(0,0))
                                        task.wait(0.1)
                                    end
                                    break
                                end
                            end
                        end
                    end
                end)
                task.wait(1)
            end
        end)
    end
end)

